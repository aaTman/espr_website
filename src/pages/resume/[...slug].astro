---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  return experiments.map((e) => ({ params: { slug: e.id }, props: { e } }));
}

const { e } = Astro.props;
const { Content } = await render(e);
const fmtMeta = [e.data.year, ...e.data.tags].filter(Boolean).join(' · ');
---
<BaseLayout title={`${e.data.title} — espr.ai`} description={e.data.description} current="resume">
  <div class="wrap">
    <div class="page-head">
      <h1>{e.data.title}</h1>
      <span class="date mono">{fmtMeta}</span>
    </div>

    {e.data.demoEmbed && (
      <iframe
        class="demo-frame"
        src={e.data.demoEmbed}
        title={`${e.data.title} — live demo`}
        loading="lazy"
      ></iframe>
    )}

    <article class="prose">
      <Content />
      <p class="small" style="margin-top: 34px;">
        {e.data.demoUrl && <a href={e.data.demoUrl}>External demo ↗</a>}
        {e.data.demoUrl && e.data.repoUrl && <span> &nbsp;·&nbsp; </span>}
        {e.data.repoUrl && <a href={e.data.repoUrl}>Repository ↗</a>}
      </p>
    </article>
  </div>
</BaseLayout>

---
interface Props {
  overlay?: boolean;      // true on the landing page (nav floats over the hero)
  current?: string;       // 'work' | 'writing' | 'about'
}
const { overlay = false, current } = Astro.props;
---
<nav class:list={['site-nav', { solid: !overlay }]}>
  <div class="wrap nav-inner">
    <a class="home" href="/">Taylor Mandelbaum</a>
    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav-menu"
      aria-label="Toggle navigation"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="nav-links" id="site-nav-menu">
      <a href="/experiments/" aria-current={current === 'work' ? 'page' : undefined}>Work</a>
      <a href="/blog/" aria-current={current === 'writing' ? 'page' : undefined}>Writing</a>
      <a href="/about/" aria-current={current === 'about' ? 'page' : undefined}>About</a>
    </div>
  </div>
</nav>

<script>
  const navs = document.querySelectorAll('.site-nav');

  navs.forEach((nav) => {
    const toggle = nav.querySelector('.nav-toggle');
    const menu = nav.querySelector('.nav-links');

    if (!toggle || !menu) return;

    const closeMenu = () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.classList.remove('is-open');
    };

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        closeMenu();
      } else {
        toggle.setAttribute('aria-expanded', 'true');
        menu.classList.add('is-open');
      }
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!nav.contains(target)) closeMenu();
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 760) closeMenu();
    });
  });
</script>
